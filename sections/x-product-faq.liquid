{{ 'component-accordion.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width section-{{ section.id }}-padding">
    {%- if section.settings.heading != blank -%}
      <h2 class="collapsible-content__heading inline-richtext {{ section.settings.heading_size }}" style="text-align: {{ section.settings.heading_alignment }}; margin-bottom: 2rem;">
        {{ section.settings.heading }}
      </h2>
    {%- endif -%}

    <div class="collapsible-content-wrapper-narrow">
      {%- for block in section.blocks -%}
        <div class="accordion" {{ block.shopify_attributes }}>
          <details id="Details-{{ block.id }}-{{ section.id }}"
            {% if section.settings.open_first and forloop.first %}open{% endif %}
          >
            <summary id="Summary-{{ block.id }}-{{ section.id }}">
              <h3 class="accordion__title inline-richtext h4">
                {{ block.settings.question }}
              </h3>
              {% render 'icon-caret' %}
            </summary>
            <div class="accordion__content rte"
              id="CollapsibleAccordion-{{ block.id }}-{{ section.id }}"
              role="region"
              aria-labelledby="Summary-{{ block.id }}-{{ section.id }}"
            >
              {{ block.settings.answer }}
            </div>
          </details>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "x-Product FAQ",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "FAQ",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Heading alignment"
    },
    {
      "type": "checkbox",
      "id": "open_first",
      "default": false,
      "label": "Open first item by default"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "background-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "default": "Question",
          "label": "Question"
        },
        {
          "type": "richtext",
          "id": "answer",
          "default": "<p>Answer</p>",
          "label": "Answer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "x-Product FAQ",
      "blocks": [
        { "type": "faq_item", "settings": { "question": "What is the warranty?", "answer": "<p>We offer a standard warranty on all products.</p>" } },
        { "type": "faq_item", "settings": { "question": "How long does shipping take?", "answer": "<p>Orders typically ship within 1 business day.</p>" } },
        { "type": "faq_item", "settings": { "question": "Do you offer returns?", "answer": "<p>Yes, we accept returns within 30 days of purchase.</p>" } }
      ]
    }
  ]
}
{% endschema %}

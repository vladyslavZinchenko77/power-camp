{%- style -%}
  .x-footer-nav-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding: 48px 0 40px;
    color: {{ section.settings.text_color }};
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__wrapper {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 40px;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__column-title {
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    margin: 0 0 16px;
    letter-spacing: 0.5px;
    color: #ffffff;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__menu-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__menu-list li {
    margin-bottom: 8px;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__menu-list a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    font-size: 1.26rem;
    transition: opacity 0.2s;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__menu-list a:hover {
    opacity: 0.7;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__social-icons {
    display: flex;
    gap: 12px;
    margin-bottom: 16px;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__social-icons a {
    color: {{ section.settings.text_color }};
    font-size: 1.4rem;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__social-icons a:hover {
    opacity: 0.7;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-text {
    font-size: 0.85rem;
    margin: 0 0 12px;
    line-height: 1.5;
    color: {{ section.settings.link_color }};
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-form {
    display: flex;
    gap: 0;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-input {
    flex: 1;
    padding: 10px 14px;
    border: 1px solid {{ section.settings.link_color }};
    background: transparent;
    color: {{ section.settings.text_color }};
    font-size: 0.85rem;
    outline: none;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-input::placeholder {
    color: {{ section.settings.link_color }};
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-btn {
    padding: 10px 20px;
    background-color: {{ section.settings.button_bg_color }};
    color: {{ section.settings.button_text_color }};
    border: none;
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .x-footer-nav-{{ section.id }} .x-footer-nav__newsletter-btn:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 749px) {
    .x-footer-nav-{{ section.id }} .x-footer-nav__wrapper {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .x-footer-nav-{{ section.id }} .x-footer-nav__wrapper {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{%- endstyle -%}

<div class="x-footer-nav-{{ section.id }}">
  <div class="page-width">
    <div class="x-footer-nav__wrapper">
      {%- for block in section.blocks -%}
        <div class="x-footer-nav__column" {{ block.shopify_attributes }}>
          {%- if block.settings.title != blank -%}
            <h4 class="x-footer-nav__column-title">{{ block.settings.title | escape }}</h4>
          {%- endif -%}

          {%- case block.type -%}
            {%- when 'menu' -%}
              {%- if block.settings.menu != blank -%}
                <ul class="x-footer-nav__menu-list">
                  {%- for link in linklists[block.settings.menu].links -%}
                    <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}

            {%- when 'newsletter' -%}
              {%- if block.settings.social_facebook != blank or block.settings.social_instagram != blank or block.settings.social_tiktok != blank or block.settings.social_youtube != blank -%}
                <div class="x-footer-nav__social-icons">
                  {%- if block.settings.social_facebook != blank -%}
                    <a href="{{ block.settings.social_facebook }}" target="_blank" aria-label="Facebook">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
                    </a>
                  {%- endif -%}
                  {%- if block.settings.social_instagram != blank -%}
                    <a href="{{ block.settings.social_instagram }}" target="_blank" aria-label="Instagram">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
                    </a>
                  {%- endif -%}
                  {%- if block.settings.social_tiktok != blank -%}
                    <a href="{{ block.settings.social_tiktok }}" target="_blank" aria-label="TikTok">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.34-6.34V9.17a8.16 8.16 0 004.76 1.52v-3.4a4.85 4.85 0 01-1-.6z"/></svg>
                    </a>
                  {%- endif -%}
                  {%- if block.settings.social_youtube != blank -%}
                    <a href="{{ block.settings.social_youtube }}" target="_blank" aria-label="YouTube">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                    </a>
                  {%- endif -%}
                </div>
              {%- endif -%}

              {%- if block.settings.newsletter_text != blank -%}
                <p class="x-footer-nav__newsletter-text">{{ block.settings.newsletter_text }}</p>
              {%- endif -%}

              {%- form 'customer', id: 'FooterNewsletter' -%}
                <input type="hidden" name="contact[tags]" value="newsletter">
                <div class="x-footer-nav__newsletter-form">
                  <input
                    type="email"
                    name="contact[email]"
                    class="x-footer-nav__newsletter-input"
                    placeholder="{{ block.settings.placeholder | default: 'Enter your email' }}"
                    required
                    autocorrect="off"
                    autocapitalize="off"
                  >
                  <button type="submit" class="x-footer-nav__newsletter-btn">
                    {{ block.settings.button_label | default: 'Submit' }}
                  </button>
                </div>
              {%- endform -%}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "x-Footer nav",
  "tag": "section",
  "class": "section",
  "max_blocks": 6,
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "default": "#1a1a1a",
      "label": "Background color"
    },
    {
      "type": "color",
      "id": "text_color",
      "default": "#ffffff",
      "label": "Text color"
    },
    {
      "type": "color",
      "id": "link_color",
      "default": "#bbbbbb",
      "label": "Link color"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "default": "#c4956a",
      "label": "Button background color"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "default": "#ffffff",
      "label": "Button text color"
    }
  ],
  "blocks": [
    {
      "type": "menu",
      "name": "Menu column",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Menu",
          "label": "Column title"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu"
        }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter + Social",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "default": "Stay Connected",
          "label": "Column title"
        },
        {
          "type": "url",
          "id": "social_facebook",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "social_instagram",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "social_tiktok",
          "label": "TikTok URL"
        },
        {
          "type": "url",
          "id": "social_youtube",
          "label": "YouTube URL"
        },
        {
          "type": "text",
          "id": "newsletter_text",
          "default": "Sign up for exclusive updates, new arrivals & insider only discounts",
          "label": "Newsletter text"
        },
        {
          "type": "text",
          "id": "placeholder",
          "default": "Enter your email",
          "label": "Input placeholder"
        },
        {
          "type": "text",
          "id": "button_label",
          "default": "Submit",
          "label": "Button label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "x-Footer nav",
      "blocks": [
        {
          "type": "menu",
          "settings": {
            "title": "Customer Service",
            "menu": "footer"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "About Us"
          }
        },
        {
          "type": "menu",
          "settings": {
            "title": "Help"
          }
        },
        {
          "type": "newsletter",
          "settings": {
            "title": "Stay Connected"
          }
        }
      ]
    }
  ]
}
{% endschema %}

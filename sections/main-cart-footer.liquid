{{ 'component-cart.css' | asset_url | stylesheet_tag }}
{{ 'component-totals.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-discounts.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width{% if cart == empty %} is-empty{% endif %}" id="main-cart-footer" data-id="{{ section.id }}">
  <div>
    <div class="cart__footer section-{{ section.id }}-padding">
      {% comment %}  
      {% assign pTags = '' %}
      {% for item in cart.items %}
        {% assign product = item.product %}
        {% for tag in product.tags %}
          {% if tag contains 'upsell:' %}
            {% unless pTags contains tag %}
              {% assign pTags = pTags | append: tag | append: ',' %}  
            {% endunless %}
          {% endif %}
        {% endfor %}
      {% endfor %}
      {% assign pTags = pTags | split: ',' %}
      {% assign results = '' %}
      {% for handle in pTags %}
        {% unless handle == blank %}
          {% assign is_exist = false %}
          {% assign hd = handle | split: 'upsell:' | last %}
          {% for item in cart.items %}
            {% if hd == item.product.handle %}
              {% assign is_exist = true %}
            {% endif %}
          {% endfor %}

          {% unless is_exist %}
            {% assign results = results | append: handle | append: ',' %}
          {% endunless %}
        {% endunless %}
      {% endfor %}
      {% assign results = results | split: ',' %}
      {% endcomment %}

        {%- assign bundles = '' | split: '' -%}
        {% assign budleList = '' %}
        {% for item in cart.items %}
          {% assign custom_product = item.product %}
          {% assign tags = custom_product.tags %}
          {% for tag in tags %}                  
                {%- if tag contains 'upsell:' -%}
                    {% assign bundle_id = tag | split: 'upsell:' | last %}
                      {%- if bundle_id contains ':' -%}
                        {%- assign priority = bundle_id | split: ':' | last -%}
                        {%- assign bundle_id = bundle_id | split: ':' | first -%}
                        {% unless budleList contains bundle_id %}
                          {%- assign bundle_id = priority | append: ':' | append: bundle_id -%}
                          {% assign budleList = budleList | append: ',' | append: bundle_id %}                        
                        {% endunless %}
                      {%- else %}
                        {% unless budleList contains bundle_id %}
                          {%- assign bundle_id = '99:' | append: bundle_id -%}
                          {% assign budleList = budleList | append: ',' | append: bundle_id %}                          
                        {% endunless %}
                      {%- endif -%}   
                {%- endif -%}           
          {% endfor %}
        {% endfor %}

        {% assign budleList = budleList | remove_first: ',' | split: ',' %}
        {% assign bundles = bundles | concat: budleList %}
        {%- assign handles = bundles | sort -%}
      
      {% if handles.size >0 %}
        <div class="cart__upsell">
          <h3 class="cart__upsell-title">
            BUNDLE WITH THIS
          </h3>

          <div class="cart__upsell-list" js-cart-upsell>
            <div class="swiper-wrapper">
              {% for bundle_item in handles %}
                    {% if bundle_item contains ':' %}
                      {% assign handle = bundle_item | split: ':' | last %}
                    {% else %}
                      {% assign handle = bundle_item %}
                    {% endif %}  
                
                {% comment %}  {% assign handle = tag | split: 'upsell:' | last %}{% endcomment %}
                {% assign bProduct = all_products[handle] %}

                <div class="swiper-slide">
                  <div class="bundle-products--item">
                    <img src="{{ bProduct.featured_image.src | img_url: 'master' }}" loading="lazy"/>
                    <div class="content">
                      <h3>{{ bProduct.title }}</h3>
                      {% assign u_coupon_flag = false %}
                      {% for tag in bProduct.tags %}
                        {% liquid
                          if tag contains 'coupon_code:'
                            assign u_coupon_flag = true
                            assign coupon_discount = tag | split: 'coupon_code:' | last | split: '#' | last | plus: 0
                            assign coupon_discount = 100 | minus: coupon_discount | times: 0.01
                            assign coupon_code = tag | split: 'coupon_code:' | last | split: '#' | first
                          endif
                        %}
                      {% endfor %}
                      <div class="price">
                        {% if u_coupon_flag %}
                          {% if bProduct.compare_at_price > bProduct.price %}
                            {% assign after_price = bProduct.price | times: coupon_discount | round: 2 %}
                            {% assign savePercent = after_price | times: 100 | divided_by: bProduct.compare_at_price | round %}
                            {% assign savePercent = 100 | minus: savePercent %}
                            <s>{{ bProduct.compare_at_price | money }}</s>
                            <span>{{ after_price | money }}</span>
                            <p class="save-message">
                              You Save {{ bProduct.compare_at_price | minus: after_price | money }} ({{ savePercent }}% OFF)
                            </p>
                            <p class="after-code">After Code: {{ coupon_code }}</p>
                          {% else %}
                            {% assign after_price = bProduct.price | times: coupon_discount | round: 2 %}
                            {% assign savePercent = after_price | times: 100 | divided_by: bProduct.price | round %}
                            {% assign savePercent = 100 | minus: savePercent %}

                            <s>{{ bProduct.price | money }}</s>
                            <span>{{ after_price | money }}</span>
                            <p class="save-message">
                              You Save {{ bProduct.price | minus: after_price | money }} ({{ savePercent }}% OFF)
                            </p>
                            <p class="after-code">After Code: {{ coupon_code }}</p>
                          {% endif %}
                        {% else %}
                          <s>{{ bProduct.compare_at_price | money }}</s>
                          {{ bProduct.price | money }}
                        {% endif %}
                      </div>

                      <div class="add-to-cart" js-upsell-product data-variant-id="{{ bProduct.variants.first.id }}">
                        Add to cart
                      </div>
                    </div>
                  </div>
                </div>
              {% endfor %}
            </div>

            <div class="swiper-button-next"></div>
            <div class="swiper-button-prev"></div>
          </div>
        </div>  
      {% endif %}
      {%- if settings.show_cart_note -%}
        <cart-note class="cart__note field">
          <label for="Cart-note">{{ 'sections.cart.note' | t }}</label>
          <textarea
            class="text-area field__input"
            name="note"
            form="cart"
            id="Cart-note"
            placeholder="{{ 'sections.cart.note' | t }}"
          >{{ cart.note }}</textarea>
        </cart-note>
      {%- endif -%}

      <div class="cart__blocks">
        {% for block in section.blocks %}
          {%- case block.type -%}
            {%- when '@app' -%}
              {% render block %}
            {%- when 'subtotal' -%}
              <div class="js-contents" {{ block.shopify_attributes }}>
                <div>
                  {%- if cart.cart_level_discount_applications.size > 0 -%}
                    <ul class="discounts list-unstyled" role="list" aria-label="{{ 'customer.order.discount' | t }}">
                      {%- for discount in cart.cart_level_discount_applications -%}
                        <li class="discounts__discount discounts__discount--position">
                          {%- render 'icon-discount' -%}
                          {{ discount.title }}
                          (-{{ discount.total_allocated_amount | money }})
                        </li>
                      {%- endfor -%}
                    </ul>
                  {%- endif -%}
                </div>

                <div class="totals">
                  <h2 class="totals__total">{{ 'sections.cart.estimated_total' | t }}</h2>
                  <p class="totals__total-value">{{ cart.total_price | money }}</p>
                </div>

                <small class="tax-note caption-large rte">
                  {%- if cart.taxes_included and shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_included_and_shipping_policy_html' | t: link: shop.shipping_policy.url }}
                  {%- elsif cart.taxes_included -%}
                    {{ 'sections.cart.taxes_included_but_shipping_at_checkout' | t }}
                  {%- elsif shop.shipping_policy.body != blank -%}
                    {{ 'sections.cart.taxes_and_shipping_policy_at_checkout_html' | t: link: shop.shipping_policy.url }}
                  {%- else -%}
                    {{ 'sections.cart.taxes_and_shipping_at_checkout' | t }}
                  {%- endif -%}
                </small>
              </div>
            {%- else -%}
              <div class="cart__ctas" {{ block.shopify_attributes }}>
                <noscript>
                  <button type="submit" class="cart__update-button button button--secondary" form="cart">
                    {{ 'sections.cart.update' | t }}
                  </button>
                </noscript>

                <button
                  type="submit"
                  id="checkout"
                  class="cart__checkout-button button"
                  name="checkout"
                  {% if cart == empty %}
                    disabled
                  {% endif %}
                  form="cart"
                >
                  {{ 'sections.cart.checkout' | t }}
                </button>
              </div>

              {%- if additional_checkout_buttons -%}
                <div class="cart__dynamic-checkout-buttons additional-checkout-buttons">
                  {{ content_for_additional_checkout_buttons }}
                </div>
              {%- endif -%}
          {%- endcase -%}
        {% endfor %}

        <div id="cart-errors"></div>
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    function isIE() {
      const ua = window.navigator.userAgent;
      const msie = ua.indexOf('MSIE ');
      const trident = ua.indexOf('Trident/');

      return msie > 0 || trident > 0;
    }

    if (!isIE()) return;
    const cartSubmitInput = document.createElement('input');
    cartSubmitInput.setAttribute('name', 'checkout');
    cartSubmitInput.setAttribute('type', 'hidden');
    document.querySelector('#cart').appendChild(cartSubmitInput);
    document.querySelector('#checkout').addEventListener('click', function (event) {
      document.querySelector('#cart').submit();
    });
  });
</script>

{% schema %}
{
  "name": "t:sections.main-cart-footer.name",
  "class": "cart__footer-wrapper",
  "settings": [
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "subtotal",
      "name": "t:sections.main-cart-footer.blocks.subtotal.name",
      "limit": 1
    },
    {
      "type": "buttons",
      "name": "t:sections.main-cart-footer.blocks.buttons.name",
      "limit": 1
    },
    {
      "type": "@app"
    }
  ]
}
{% endschema %}
